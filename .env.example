# Database connection configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=landmarks_db
DB_USER=landmarks_user
DB_PASSWORD=landmarks_password

# Authentication configuration
JWT_ACCESS_SECRET=your_super_secret_jwt_access_key_change_in_production
JWT_REFRESH_SECRET=your_super_secret_jwt_refresh_key_change_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Rate limiting
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=5
